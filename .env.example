# URL publique de l'application (liens dans les e-mails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session (min. 32 caractères en production)
SESSION_SECRET=change_me_to_a_long_random_secret_32_chars

# SMTP — Mailpit en local (docker compose up mailpit -d)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Shifaa Parapharmacie <noreply@shifaa.dz>
